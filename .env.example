# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# MCP Server
# Shared Secret fuer den MCP-Endpoint (/api/mcp/sse), z. B. generieren mit: openssl rand -hex 32
# Requests ohne "Authorization: Bearer <token>" werden abgelehnt.
MCP_AUTH_TOKEN=your_mcp_auth_token_here

# Firebase Admin (Server)
# Service-Account-JSON als einzeiliger String (Firebase Console -> Projekteinstellungen
# -> Dienstkonten -> "Neuen privaten Schluessel generieren", dann z. B.:
#   cat serviceAccount.json | tr -d '\n')
# Benoetigt fuer /api/user/apiKey (persoenliche API-Keys) und deren Nutzung
# als MCP-Credential. Ohne diesen Wert antwortet die Key-Verwaltung mit 503.
FIREBASE_SERVICE_ACCOUNT_KEY=
