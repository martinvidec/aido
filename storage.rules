rules_version = '2';

// Deny-by-default: only the user-scoped uploads prefix below is accessible,
// everything else in the bucket is unreadable/unwritable for clients.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      // Owner-only uploads, images only, max 5 MB. `write` is split so that
      // deletes (request.resource == null) don't trip the content checks.
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
